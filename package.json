{
	"name": "@ctx-core/html",
	"version": "11.8.86",
	"description": "ctx-core html",
	"keywords": [
		"ctx-core",
		"html"
	],
	"homepage": "https://github.com/ctx-core/html#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/html/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/html.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-html@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:size && bun run test:types && bun run test:unit",
		"test:size": "size-limit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"@size-limit/preset-small-lib": "^12.0.0",
		"ctx-core": "*",
		"size-limit": "^12.0.0"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"size-limit": [
		{
			"name": "class_",
			"import": {
				".": "{ class_ }"
			},
			"limit": "94 B"
		}
	]
}
